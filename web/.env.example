# Blind Cargo Judge — frontend config (Vite). Copy to `.env` to override.

# Deployed CargoManifestJudge (commit-reveal) contract on Ritual.
VITE_CONTRACT_ADDRESS=0x679666151d5C2c329a23f5E23C659C383d5DAf2F

# Ritual Chain JSON-RPC endpoint
VITE_RITUAL_RPC_URL=https://rpc.ritualfoundation.org

# Ritual Chain numeric chain id
VITE_RITUAL_CHAIN_ID=1979

# Ritual LLM executor / precompile-callback address used when building the
# judgeAll LLM request.
VITE_RITUAL_EXECUTOR_ADDRESS=0xB42e435c4252A5a2E7440e37B609F00c61a0c91B
